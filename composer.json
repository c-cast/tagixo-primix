{
    "name": "ccast/tagixo-primix",
    "description": "Primix SDK for Tagixo Visual Builder",
    "type": "library",
    "version": "1.0",
    "keywords": [
        "laravel",
        "primix",
        "tagixo",
        "visual-builder"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Mikrowl Team",
            "email": "dev@mikrowl.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "ccast/tagixo": "*",
        "primix/primix": "*",
        "symfony/expression-language": "^6.4|^7.0"
    },
    "autoload": {
        "psr-4": {
            "Ccast\\TagixoPrimix\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ccast\\TagixoPrimix\\TagixoPrimixServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
